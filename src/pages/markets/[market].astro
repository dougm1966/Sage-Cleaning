---
import Page from '../../layouts/Page.astro';
import { markets, type Market } from '../../data/markets.ts';
import { servicesBySlug } from '../../data/services.ts';

export async function getStaticPaths() {
  return markets.map((m) => ({
    params: { market: m.slug },
    props: { market: m },
  }));
}

interface Props {
  market: Market;
}
const { market: m } = Astro.props;

const siteUrl = 'https://www.yoursagecleaning.com';
const pageUrl = `${siteUrl}/markets/${m.slug}`;

const linkedServices = m.serviceLinks.map((sl) => {
  const svc = servicesBySlug[sl.serviceSlug];
  return svc ? { name: svc.name, slug: svc.slug, desc: sl.desc } : null;
}).filter((s): s is { name: string; slug: string; desc: string } => Boolean(s));

const otherMarkets = markets.filter((x) => x.slug !== m.slug).slice(0, 3);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Our Markets', item: `${siteUrl}/markets` },
    { '@type': 'ListItem', position: 3, name: m.name, item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: m.heroTitle,
  serviceType: m.heroTitle,
  description: m.shortDesc,
  url: pageUrl,
  audience: {
    '@type': 'Audience',
    audienceType: m.audience,
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Big Horn Basin, Wyoming' },
    { '@type': 'City', name: 'Cody, WY' },
    { '@type': 'City', name: 'Powell, WY' },
  ],
  provider: {
    '@type': ['LocalBusiness', 'HouseCleaning'],
    name: 'SAGE Cleaning LLC',
    telephone: '307-254-5338',
    email: 'yoursagecleaning@gmail.com',
    url: siteUrl,
    image:
      'https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/xaTIbq2shiuyCF0YZ1ud/media/64fb9b62fc1b6574d9958208.png',
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'WY',
      addressCountry: 'US',
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: m.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Page
  title={m.metaTitle}
  description={m.metaDescription}
  heroTitle={m.heroTitle}
  heroSubtitle={m.heroSubtitle}
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(faqSchema)} />
  <link rel="canonical" href={pageUrl} slot="head" />

  <!-- Breadcrumb -->
  <section class="bg-white border-b border-gray-100">
    <div class="container mx-auto px-6 md:px-12 py-4">
      <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-gray-400">
        <a href="/" class="hover:text-sage-gold">Home</a>
        <span class="mx-2">/</span>
        <a href="/markets" class="hover:text-sage-gold">Our Markets</a>
        <span class="mx-2">/</span>
        <span class="text-sage-dark font-bold">{m.name}</span>
      </nav>
    </div>
  </section>

  <!-- Intro: problem + solution + inline quote -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <span class="eyebrow" data-animate="fade-up">{m.heroEyebrow}</span>
          <h1 class="font-serif text-4xl md:text-5xl text-sage-dark leading-tight mb-8" data-animate="fade-up">
            {m.heroTitle.split(' ').slice(0, -2).join(' ')}<br />
            <em class="text-sage-gold not-italic">{m.heroTitle.split(' ').slice(-2).join(' ')}</em>
          </h1>
          <div class="space-y-5 section-body" data-animate="fade-up">
            <p>{m.problem}</p>
            <p>{m.solution}</p>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-4" data-animate="fade-up">
            <a href="tel:3072545338" class="btn-primary">Call 307-254-5338</a>
            <a href="#market-quote" class="btn-gold">Get A Free Quote</a>
          </div>
        </div>

        <!-- Inline quote form -->
        <div id="market-quote" class="bg-sage-off-white border border-gray-100 p-8 md:p-10 lg:sticky lg:top-28" data-animate="fade-up">
          <p class="text-xs font-bold text-sage-dark/60 uppercase tracking-widest mb-3">Serving the Big Horn Basin since 2019</p>
          <span class="eyebrow">Free Quote · No Contract</span>
          <h2 class="font-serif text-2xl md:text-3xl text-sage-dark leading-tight mt-3 mb-2">
            Get your <em class="text-sage-gold not-italic">{m.name}</em> quote
          </h2>
          <p class="text-gray-500 text-sm mb-6">Most clients hear back the same day. Required fields marked.</p>

          <form
            action="/forms/contact-handler.php"
            method="POST"
            class="space-y-4"
            data-market-form
          >
            <input type="hidden" name="market" value={m.name} />
            <input type="hidden" name="source" value="market_page_inline" />
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

            <div>
              <label for={`name-${m.slug}`} class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Your Name *</label>
              <input
                type="text"
                id={`name-${m.slug}`}
                name="name"
                required
                placeholder="Jane Smith"
                class="w-full bg-white border border-gray-200 focus:border-sage-gold focus:outline-none px-4 py-3 text-sage-dark text-sm transition-colors duration-200 placeholder-gray-300"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for={`phone-${m.slug}`} class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Phone *</label>
                <input
                  type="tel"
                  id={`phone-${m.slug}`}
                  name="phone"
                  required
                  placeholder="307-000-0000"
                  class="w-full bg-white border border-gray-200 focus:border-sage-gold focus:outline-none px-4 py-3 text-sage-dark text-sm transition-colors duration-200 placeholder-gray-300"
                />
              </div>
              <div>
                <label for={`email-${m.slug}`} class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Email *</label>
                <input
                  type="email"
                  id={`email-${m.slug}`}
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="w-full bg-white border border-gray-200 focus:border-sage-gold focus:outline-none px-4 py-3 text-sage-dark text-sm transition-colors duration-200 placeholder-gray-300"
                />
              </div>
            </div>

            <div>
              <label for={`message-${m.slug}`} class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Tell us about your situation</label>
              <textarea
                id={`message-${m.slug}`}
                name="message"
                rows="3"
                placeholder="Property type, frequency, timeline..."
                class="w-full bg-white border border-gray-200 focus:border-sage-gold focus:outline-none px-4 py-3 text-sage-dark text-sm transition-colors duration-200 placeholder-gray-300"
              ></textarea>
            </div>

            <button type="submit" class="btn-gold w-full text-center">
              Get My Free Quote →
            </button>

            <p class="text-xs text-gray-400 text-center pt-1">
              Prefer to talk? Call <a href="tel:3072545338" class="text-sage-gold hover:underline font-bold">307-254-5338</a>.
            </p>

            <div data-form-error class="hidden text-sm text-red-600 text-center"></div>
          </form>

          <div data-form-success class="hidden bg-sage-gold/10 border border-sage-gold p-6 text-center mt-4">
            <p class="font-bold text-sage-dark mb-1">Quote request sent!</p>
            <p class="text-gray-500 text-sm">We'll be in touch shortly. For faster service, call 307-254-5338.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why SAGE for this market -->
  <section class="py-20 md:py-24 bg-sage-off-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow" data-animate="fade-up">Why {m.name} Pick SAGE</span>
        <h2 class="section-heading mb-4" data-animate="fade-up">
          Built for the way<br />
          <em class="text-sage-gold not-italic">you actually work</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate="stagger-children">
        {m.benefits.map((b, i) => (
          <div class="bg-white border border-gray-100 p-8">
            <span class="block text-xs font-bold text-sage-gold uppercase tracking-widest mb-3">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-serif text-xl text-sage-dark mb-3">{b.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recommended services for this market -->
  <section class="py-20 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow" data-animate="fade-up">Services {m.name} Use</span>
        <h2 class="section-heading mb-4" data-animate="fade-up">
          The cleans that fit<br />
          <em class="text-sage-gold not-italic">{m.name.toLowerCase()}</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate="stagger-children">
        {linkedServices.map((s, i) => (
          <a
            href={`/services#${s.slug}`}
            class="group block bg-sage-off-white border border-gray-100 hover:border-sage-gold hover:shadow-xl transition-all duration-300 p-8"
          >
            <span class="block text-xs font-bold text-sage-gold uppercase tracking-widest mb-4">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-serif text-xl text-sage-dark mb-3 group-hover:text-sage-gold transition-colors duration-300">
              {s.name}
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6">{s.desc}</p>
            <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-sage-dark group-hover:text-sage-gold transition-colors">
              Learn More <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>

      <!-- What's included -->
      <div class="mt-16 bg-sage-off-white border border-gray-100 p-8 md:p-10" data-animate="fade-up">
        <h3 class="font-serif text-2xl md:text-3xl text-sage-dark mb-6">What's typically included</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {m.serviceList.map((s) => (
            <li class="flex items-center gap-3 text-sm text-gray-600">
              <span class="w-4 h-px bg-sage-gold inline-block flex-shrink-0"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  {m.testimonial && (
    <section class="py-20 md:py-24 bg-sage-off-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-3xl mx-auto text-center">
          <span class="eyebrow" data-animate="fade-up">Real Client · Real Result</span>
          <blockquote class="font-serif text-2xl md:text-3xl text-sage-dark leading-snug mt-6 mb-8" data-animate="fade-up">
            “{m.testimonial.quote}”
          </blockquote>
          <p class="text-sm text-sage-dark font-bold uppercase tracking-widest" data-animate="fade-up">
            {m.testimonial.author}
          </p>
          <p class="text-xs text-gray-500 mt-1" data-animate="fade-up">{m.testimonial.role}</p>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="eyebrow" data-animate="fade-up">Common Questions</span>
          <h2 class="section-heading" data-animate="fade-up">
            {m.name} —<br />
            <em class="text-sage-gold not-italic">Your questions answered</em>
          </h2>
        </div>

        <div class="space-y-4" data-animate="stagger-children">
          {m.faq.map((item) => (
            <details class="group bg-sage-off-white border border-gray-100 hover:border-sage-gold transition-colors">
              <summary class="flex items-center justify-between cursor-pointer p-6 list-none">
                <span class="font-serif text-lg text-sage-dark pr-6">{item.q}</span>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-sage-gold transition-transform group-open:rotate-45 text-2xl leading-none">+</span>
              </summary>
              <div class="px-6 pb-6 text-gray-500 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Other markets we serve -->
  <section class="py-16 md:py-20 bg-sage-off-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-5xl mx-auto">
        <span class="eyebrow" data-animate="fade-up">Also Serving</span>
        <h2 class="font-serif text-3xl md:text-4xl text-sage-dark mb-10" data-animate="fade-up">
          Other groups we <em class="text-sage-gold not-italic">clean for</em>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate="stagger-children">
          {otherMarkets.map((om) => (
            <a
              href={`/markets/${om.slug}`}
              class="group block bg-white border border-gray-100 hover:border-sage-gold hover:shadow-lg transition-all duration-300 p-6"
            >
              <span class="text-3xl block mb-3">{om.icon}</span>
              <h3 class="font-serif text-xl text-sage-dark group-hover:text-sage-gold transition-colors mb-2">
                {om.name}
              </h3>
              <p class="text-gray-500 text-sm italic mb-4">{om.tagline}</p>
              <span class="text-xs font-bold uppercase tracking-widest text-sage-dark group-hover:text-sage-gold transition-colors">
                View {om.name.split(' ')[0]} →
              </span>
            </a>
          ))}
        </div>

        <div class="mt-10 text-center" data-animate="fade-up">
          <a href="/markets" class="inline-block text-sm font-bold uppercase tracking-widest text-sage-dark hover:text-sage-gold transition-colors">
            See All Who We Serve →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="py-20 md:py-24 bg-sage-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_30%_50%,_#D1AF60_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
      <span class="eyebrow text-sage-gold/70" data-animate="fade-up">Ready to Get Started?</span>
      <h2 class="font-serif text-3xl md:text-5xl text-white mb-6 max-w-2xl mx-auto" data-animate="fade-up">
        {m.tagline}
      </h2>
      <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto" data-animate="fade-up">
        Free quote, no contract, same-day response. Most clients are on the schedule within the week.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
        <a href="tel:3072545338" class="btn-gold">Call 307-254-5338</a>
        <a href="/contact" class="inline-block border-2 border-white/30 text-white font-bold uppercase tracking-widest text-sm px-10 py-5 hover:border-sage-gold hover:text-sage-gold transition-all duration-300">
          Send A Message
        </a>
      </div>
    </div>
  </section>
</Page>

<script>
  const form = document.querySelector<HTMLFormElement>('form[data-market-form]');
  if (form) {
    const success = form.parentElement?.querySelector<HTMLElement>('[data-form-success]');
    const errorEl = form.querySelector<HTMLElement>('[data-form-error]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorEl) {
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
      }
      const data = new FormData(form);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          return;
        }
        throw new Error('Submission failed');
      } catch {
        if (errorEl) {
          errorEl.textContent = 'Something went wrong. Please call 307-254-5338.';
          errorEl.classList.remove('hidden');
        }
      }
    });
  }
</script>
