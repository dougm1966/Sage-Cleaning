---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — SAGE Cleaning" description="The page you're looking for doesn't exist.">
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-24 bg-[#FAF9F6]">
    <div class="max-w-2xl text-center">
      <p class="text-[#D1AF60] font-semibold tracking-widest text-sm uppercase mb-4">404</p>
      <h1 class="font-serif text-5xl md:text-6xl text-[#093626] mb-6">Page not found</h1>
      <p class="text-lg text-[#093626]/70 mb-10">
        The page you're looking for doesn't exist or has moved. Let's get you back on track.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="inline-block bg-[#093626] text-[#FAF9F6] px-8 py-4 rounded-full font-medium hover:bg-[#093626]/90 transition">
          Back to home
        </a>
        <a href="/contact" class="inline-block border border-[#093626] text-[#093626] px-8 py-4 rounded-full font-medium hover:bg-[#093626] hover:text-[#FAF9F6] transition">
          Contact us
        </a>
      </div>
    </div>
  </section>
</Base>
