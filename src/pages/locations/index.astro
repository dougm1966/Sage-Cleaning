---
import Page from '../../layouts/Page.astro';
import { locations } from '../../data/locations.ts';

const siteUrl = 'https://www.yoursagecleaning.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'SAGE Cleaning Service Areas',
  description: 'Cities and communities served by SAGE Cleaning across the Big Horn Basin, Wyoming.',
  itemListElement: locations.map((loc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Place',
      name: `${loc.name}, ${loc.stateAbbr}`,
      url: `${siteUrl}/locations/${loc.slug}`,
      address: {
        '@type': 'PostalAddress',
        addressLocality: loc.name,
        addressRegion: loc.stateAbbr,
        addressCountry: 'US',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: loc.lat,
        longitude: loc.lng,
      },
    },
  })),
};
---

<Page
  title="Service Areas | SAGE Cleaning Big Horn Basin Wyoming"
  description="SAGE Cleaning serves 12 communities across the Big Horn Basin, Wyoming — Powell, Cody, Greybull, Basin, Lovell, and more. Find professional cleaning service in your city."
  heroTitle="Service Areas"
  heroSubtitle="Twelve Big Horn Basin communities. One trusted local team."
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(itemListSchema)} />

  <!-- Intro -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-3xl">
        <span class="eyebrow" data-animate="fade-up">Where We Clean</span>
        <h2 class="section-heading mb-6" data-animate="fade-up">
          What areas does<br />
          <em class="text-sage-gold not-italic">SAGE Cleaning serve?</em>
        </h2>
        <p class="section-body" data-animate="fade-up">
          SAGE Cleaning provides residential, commercial, vacation rental, deep, and move-in/move-out cleaning across twelve communities in the Big Horn Basin region of Wyoming. From Powell and Cody in Park County to Lovell, Greybull, and Basin in Big Horn County, our local crews keep homes and businesses spotless on weekly, bi-weekly, or one-time schedules. Click your city below for service details, local FAQ, and a free quote — or call <a href="tel:3072545338" class="text-sage-gold font-bold hover:underline">307-254-5338</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Locations grid -->
  <section class="py-16 md:py-20 bg-sage-off-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="stagger-children">
        {locations.map((loc) => (
          <a
            href={`/locations/${loc.slug}`}
            class="group block bg-white border border-gray-100 hover:border-sage-gold hover:shadow-xl transition-all duration-300 p-8"
          >
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-serif text-2xl text-sage-dark group-hover:text-sage-gold transition-colors duration-300">
                  {loc.name}
                </h3>
                <span class="block text-xs text-gray-400 uppercase tracking-widest font-medium mt-1">
                  {loc.county}, {loc.stateAbbr}
                </span>
              </div>
              <svg class="w-5 h-5 text-sage-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <p class="text-gray-500 text-sm leading-relaxed mb-6 italic">
              {loc.tagline}
            </p>
            <div class="w-10 h-1 bg-sage-gold mb-4 transition-all duration-300 group-hover:w-16"></div>
            <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-sage-dark group-hover:text-sage-gold transition-colors">
              View {loc.name} Cleaning Services
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="py-20 md:py-24 bg-sage-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_30%_50%,_#D1AF60_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
      <span class="eyebrow text-sage-gold/70" data-animate="fade-up">Don't See Your Town?</span>
      <h2 class="font-serif text-3xl md:text-5xl text-white mb-6 max-w-2xl mx-auto" data-animate="fade-up">
        We may still be able to help.
      </h2>
      <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto" data-animate="fade-up">
        We regularly serve communities throughout Big Horn County and Park County, Wyoming. Call us — we'll let you know if your address is on our route.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
        <a href="tel:3072545338" class="btn-gold">Call 307-254-5338</a>
        <a href="/contact" class="inline-block border-2 border-white/30 text-white font-bold uppercase tracking-widest text-sm px-10 py-5 hover:border-sage-gold hover:text-sage-gold transition-all duration-300">
          Send A Message
        </a>
      </div>
    </div>
  </section>
</Page>
