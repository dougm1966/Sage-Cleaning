---
import Page from '../../../layouts/Page.astro';
import { locations, locationsBySlug, type Location } from '../../../data/locations.ts';
import { services, servicesBySlug, type ServiceDef } from '../../../data/services.ts';

export async function getStaticPaths() {
  const paths = [];
  for (const loc of locations) {
    for (const svc of services) {
      paths.push({
        params: { city: loc.slug, service: svc.slug },
        props: { location: loc, service: svc },
      });
    }
  }
  return paths;
}

interface Props {
  location: Location;
  service: ServiceDef;
}
const { location: loc, service: svc } = Astro.props;

const siteUrl = 'https://www.yoursagecleaning.com';
const pageUrl = `${siteUrl}/locations/${loc.slug}/${svc.slug}`;

const cityIntro = svc.cityIntroTemplate(loc.name, loc.localContext);
const cityFaq = svc.faq(loc.name);

const otherServices = services.filter((s) => s.slug !== svc.slug);
const neighbors = loc.neighbors
  .map((slug) => locationsBySlug[slug])
  .filter((n): n is Location => Boolean(n));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
    { '@type': 'ListItem', position: 3, name: loc.name, item: `${siteUrl}/locations/${loc.slug}` },
    { '@type': 'ListItem', position: 4, name: svc.name, item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${svc.name} in ${loc.name}, ${loc.stateAbbr}`,
  serviceType: svc.serviceType,
  description: `${svc.name} in ${loc.name}, Wyoming. ${svc.intro}`,
  url: pageUrl,
  areaServed: {
    '@type': 'City',
    name: `${loc.name}, ${loc.stateAbbr}`,
    address: {
      '@type': 'PostalAddress',
      addressLocality: loc.name,
      addressRegion: loc.stateAbbr,
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: loc.lat,
      longitude: loc.lng,
    },
  },
  provider: {
    '@type': ['LocalBusiness', 'HouseCleaning'],
    name: 'SAGE Cleaning LLC',
    telephone: '307-254-5338',
    email: 'yoursagecleaning@gmail.com',
    url: siteUrl,
    image:
      'https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/xaTIbq2shiuyCF0YZ1ud/media/64fb9b62fc1b6574d9958208.png',
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      addressLocality: loc.name,
      addressRegion: loc.stateAbbr,
      addressCountry: 'US',
    },
    sameAs: ['https://www.facebook.com/yoursagecleaning'],
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `${svc.name} inclusions`,
    itemListElement: svc.inclusions.map((inc) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: inc.title,
        description: inc.desc,
      },
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: cityFaq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const title = `${svc.name} in ${loc.name}, WY | SAGE Cleaning | Free Quote`;
const description = `Professional ${svc.metaKeyword} in ${loc.name}, Wyoming. Locally owned, insured, background-checked team. Free quote at 307-254-5338 — same-day response.`.slice(0, 160);
---

<Page
  title={title}
  description={description}
  heroTitle={`${svc.shortName} Cleaning in ${loc.name}`}
  heroSubtitle={`${loc.county} · ${loc.state}`}
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Visible breadcrumb -->
  <section class="bg-white border-b border-gray-100">
    <div class="container mx-auto px-6 md:px-12 py-4">
      <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-gray-400">
        <a href="/" class="hover:text-sage-gold">Home</a>
        <span class="mx-2">/</span>
        <a href="/locations" class="hover:text-sage-gold">Locations</a>
        <span class="mx-2">/</span>
        <a href={`/locations/${loc.slug}`} class="hover:text-sage-gold">{loc.name}</a>
        <span class="mx-2">/</span>
        <span class="text-sage-dark font-bold">{svc.shortName}</span>
      </nav>
    </div>
  </section>

  <!-- City + service intro -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <div class="lg:col-span-2">
          <span class="eyebrow" data-animate="fade-up">{svc.heroEyebrow} · {loc.name}, {loc.stateAbbr}</span>
          <h1 class="font-serif text-4xl md:text-5xl text-sage-dark leading-tight mb-8" data-animate="fade-up">
            {svc.name} in<br />
            <em class="text-sage-gold not-italic">{loc.name}, Wyoming</em>
          </h1>

          <div class="space-y-5 section-body" data-animate="fade-up">
            <p>{cityIntro}</p>
            <p>{svc.intro}</p>
          </div>

          <div class="mt-10 flex flex-col sm:flex-row gap-4" data-animate="fade-up">
            <a href="tel:3072545338" class="btn-primary">Call 307-254-5338</a>
            <a href="/contact" class="btn-gold">Get A Free Quote</a>
          </div>
        </div>

        <!-- Quick-facts panel -->
        <aside class="lg:col-span-1" data-animate="fade-up">
          <div class="bg-sage-off-white border border-gray-100 p-8 sticky top-32">
            <span class="block text-xs font-bold uppercase tracking-widest text-sage-gold mb-4">
              Quick Facts
            </span>
            <dl class="space-y-5">
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">Service</dt>
                <dd class="text-sage-dark font-bold">{svc.name}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">City</dt>
                <dd class="text-sage-dark font-bold">{loc.name}, {loc.stateAbbr}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">County</dt>
                <dd class="text-sage-dark font-bold">{loc.county}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">Typical Duration</dt>
                <dd class="text-sage-dark font-bold">{svc.duration}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">Frequency</dt>
                <dd class="text-sage-dark font-bold">{svc.frequency}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-gray-400 font-bold mb-1">Insured & Background-Checked</dt>
                <dd class="text-sage-dark font-bold">Yes — every cleaner</dd>
              </div>
            </dl>
            <a href="tel:3072545338" class="block mt-6 text-center btn-gold w-full">Call 307-254-5338</a>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="py-16 md:py-20 bg-sage-off-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-4xl">
        <span class="eyebrow" data-animate="fade-up">Who It's For</span>
        <h2 class="section-heading mb-10" data-animate="fade-up">
          Built for <em class="text-sage-gold not-italic">{loc.name}</em> homes & businesses like yours
        </h2>

        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4" data-animate="stagger-children">
          {svc.whoFor.map((who) => (
            <li class="flex items-start gap-4 bg-white border border-gray-100 p-5">
              <svg class="w-5 h-5 text-sage-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span class="text-sage-dark font-medium">{who}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-20 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow" data-animate="fade-up">What's Included</span>
        <h2 class="section-heading" data-animate="fade-up">
          Every {svc.shortName} Clean in {loc.name},<br />
          <em class="text-sage-gold not-italic">Built on the Same 47-Point Standard</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto" data-animate="stagger-children">
        {svc.inclusions.map((inc, i) => (
          <article class="bg-sage-off-white border border-gray-100 hover:border-sage-gold transition-colors p-8">
            <span class="block text-xs font-bold text-sage-gold uppercase tracking-widest mb-3">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-serif text-lg text-sage-dark mb-2">{inc.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{inc.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- City-specific FAQ -->
  <section class="py-20 md:py-28 bg-sage-off-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="eyebrow" data-animate="fade-up">Common Questions</span>
          <h2 class="section-heading" data-animate="fade-up">
            {svc.shortName} Cleaning in {loc.name} —<br />
            <em class="text-sage-gold not-italic">Answers</em>
          </h2>
        </div>

        <div class="space-y-4" data-animate="stagger-children">
          {cityFaq.map((item) => (
            <details class="group bg-white border border-gray-100 hover:border-sage-gold transition-colors">
              <summary class="flex items-center justify-between cursor-pointer p-6 list-none">
                <span class="font-serif text-lg text-sage-dark pr-6">{item.q}</span>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-sage-gold transition-transform group-open:rotate-45 text-2xl leading-none">+</span>
              </summary>
              <div class="px-6 pb-6 text-gray-500 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Other services in this city -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-5xl mx-auto">
        <span class="eyebrow" data-animate="fade-up">Also Available in {loc.name}</span>
        <h2 class="font-serif text-3xl md:text-4xl text-sage-dark mb-10" data-animate="fade-up">
          Other cleaning services in <em class="text-sage-gold not-italic">{loc.name}</em>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" data-animate="stagger-children">
          {otherServices.map((s) => (
            <a
              href={`/locations/${loc.slug}/${s.slug}`}
              class="group block bg-sage-off-white border border-gray-100 hover:border-sage-gold hover:shadow-lg transition-all duration-300 p-6"
            >
              <span class="block text-xs font-bold text-sage-gold uppercase tracking-widest mb-3">
                {s.heroEyebrow}
              </span>
              <h3 class="font-serif text-lg text-sage-dark mb-2 group-hover:text-sage-gold transition-colors">
                {s.shortName} in {loc.name}
              </h3>
              <span class="text-xs font-bold uppercase tracking-widest text-sage-dark group-hover:text-sage-gold transition-colors">
                Learn More →
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Same service in nearby cities -->
  {neighbors.length > 0 && (
    <section class="py-16 md:py-20 bg-sage-off-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-5xl mx-auto">
          <span class="eyebrow" data-animate="fade-up">Nearby Service Areas</span>
          <h2 class="font-serif text-3xl md:text-4xl text-sage-dark mb-10" data-animate="fade-up">
            {svc.shortName} cleaning in <em class="text-sage-gold not-italic">nearby Big Horn Basin towns</em>
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate="stagger-children">
            {neighbors.map((n) => (
              <a
                href={`/locations/${n.slug}/${svc.slug}`}
                class="group block bg-white border border-gray-100 hover:border-sage-gold hover:shadow-lg transition-all duration-300 p-6"
              >
                <div class="flex items-center gap-3 mb-2">
                  <svg class="w-5 h-5 text-sage-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                  <h3 class="font-serif text-lg text-sage-dark group-hover:text-sage-gold transition-colors">
                    {n.name}, {n.stateAbbr}
                  </h3>
                </div>
                <p class="text-gray-500 text-sm italic mb-4">{svc.shortName} cleaning in {n.name}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-sage-dark group-hover:text-sage-gold transition-colors">
                  View →
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA band -->
  <section class="py-20 md:py-24 bg-sage-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_30%_50%,_#D1AF60_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
      <span class="eyebrow text-sage-gold/70" data-animate="fade-up">Ready to Book?</span>
      <h2 class="font-serif text-3xl md:text-5xl text-white mb-6 max-w-2xl mx-auto" data-animate="fade-up">
        Free quote for <em class="text-sage-gold not-italic">{svc.shortName}</em> cleaning in {loc.name}.
      </h2>
      <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto" data-animate="fade-up">
        Same-day response. No long-term contract. Insured and background-checked team.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
        <a href="tel:3072545338" class="btn-gold">Call 307-254-5338</a>
        <a href="/contact" class="inline-block border-2 border-white/30 text-white font-bold uppercase tracking-widest text-sm px-10 py-5 hover:border-sage-gold hover:text-sage-gold transition-all duration-300">
          Send A Message
        </a>
      </div>
    </div>
  </section>
</Page>
