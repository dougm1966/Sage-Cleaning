---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Expert cleaning services in the Big Horn Basin. SAGE Cleaning — vetted, insured, and dedicated to your home or business.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific head content (schema, etc.) -->
    <slot name="head" />

    <!-- Schema.org Organization -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SAGE Cleaning LLC",
      "url": "https://www.yoursagecleaning.com",
      "telephone": "307-254-5338",
      "email": "yoursagecleaning@gmail.com",
      "sameAs": [
        "https://www.facebook.com/yoursagecleaning"
      ]
    }
    </script>

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "HouseCleaning"],
      "name": "SAGE Cleaning LLC",
      "description": "Expert residential, commercial, and vacation rental cleaning services in the Big Horn Basin, Wyoming. Vetted, insured, locally owned cleaners.",
      "url": "https://www.yoursagecleaning.com",
      "telephone": "307-254-5338",
      "email": "yoursagecleaning@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Powell",
        "addressRegion": "WY",
        "addressCountry": "US"
      },
      "areaServed": [
        "Worland, WY",
        "Basin, WY",
        "Greybull, WY",
        "Lovell, WY",
        "Powell, WY",
        "Big Horn County, WY",
        "Big Horn Basin, WY"
      ],
      "priceRange": "$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        "https://www.facebook.com/yoursagecleaning"
      ]
    }
    </script>
  </head>
  <body>
    <slot />

    <!-- Lenis + GSAP init -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        lerp: 0.08,
        smoothWheel: true,
        orientation: 'vertical',
      });

      // Drive Lenis via GSAP ticker for ScrollTrigger sync
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);
      lenis.on('scroll', ScrollTrigger.update);

      // Anchor scroll via Lenis
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const target = anchor.getAttribute('href');
          if (target) lenis.scrollTo(target, { offset: -96 });
        });
      });

      // Expose for animations.js
      (window as any).__lenis = lenis;
    </script>

    <!-- Page animations -->
    <script>
      import '../scripts/animations.js';
    </script>
  </body>
</html>
