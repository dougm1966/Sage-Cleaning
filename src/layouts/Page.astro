---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  heroTitle: string;
  heroSubtitle?: string;
}
const { title, description, heroTitle, heroSubtitle } = Astro.props;
---

<Base title={title} description={description}>
  <slot name="head" slot="head" />
  <Nav />

  <!-- Inner page hero -->
  <section class="relative bg-sage-dark pt-28 pb-10 md:pt-32 md:pb-12 overflow-hidden">
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle_at_20%_50%,_#D1AF60_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
      <span class="eyebrow text-sage-gold/70" data-animate="fade-up">SAGE Cleaning</span>
      <h1 class="font-serif text-4xl md:text-6xl text-white leading-tight mb-4" data-animate="fade-up">
        {heroTitle}
      </h1>
      {heroSubtitle && (
        <p class="text-white/60 text-lg max-w-xl mx-auto" data-animate="fade-up">
          {heroSubtitle}
        </p>
      )}
    </div>
  </section>

  <main class="pb-20 md:pb-0">
    <slot />
  </main>

  <!-- Mobile sticky call button -->
  <a
    href="tel:3072545338"
    class="md:hidden fixed bottom-4 inset-x-4 z-40 bg-sage-gold text-sage-dark font-bold uppercase tracking-widest text-sm px-6 py-4 text-center shadow-2xl flex items-center justify-center gap-3 hover:bg-sage-dark hover:text-sage-gold transition-colors duration-300"
    aria-label="Call SAGE Cleaning"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
    </svg>
    Call 307-254-5338
  </a>

  <Footer />
</Base>
